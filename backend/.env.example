# ============================================================
# Eskişehir Event API - Environment Variables Reference
# ============================================================
# Copy this file to .env (or set variables in your shell/CI/CD).
# .env files are git-ignored — never commit real credentials.
# ============================================================

# ──────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT (application.properties defaults)
# Used when running WITHOUT --spring.profiles.active=prod
#
# The docker-compose.yml ships with these exact defaults,
# so you can run "docker-compose up -d" and start the app
# with no extra configuration needed.
# ──────────────────────────────────────────────────────────
DB_USERNAME=eskisehir_user
DB_PASSWORD=eskisehir_pass

# ──────────────────────────────────────────────────────────
# PRODUCTION (application-prod.properties)
# Used when running with --spring.profiles.active=prod
# These have NO defaults — the app will refuse to start
# if any of them are missing.
# ──────────────────────────────────────────────────────────

# Full JDBC URL for the production PostgreSQL database.
# Examples:
#   Plain:  jdbc:postgresql://db.example.com:5432/eskisehir_events_db
#   SSL:    jdbc:postgresql://db.example.com:5432/eskisehir_events_db?sslmode=require
APP_DB_URL=jdbc:postgresql://localhost:5432/eskisehir_events_db

# PostgreSQL credentials for the production database
APP_DB_USERNAME=eskisehir_user
APP_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ──────────────────────────────────────────────────────────
# JWT (required in all profiles, has dev default only)
# ──────────────────────────────────────────────────────────

# HMAC-SHA256 secret key — must be at least 32 characters.
# Generate a strong key: openssl rand -base64 48
APP_JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG_SECRET_KEY

# Token TTL in milliseconds
#   86400000  = 24 hours  (recommended for dev)
#   604800000 = 7 days    (recommended for prod with refresh tokens)
APP_JWT_EXPIRATION=86400000

# ──────────────────────────────────────────────────────────
# HOW TO USE
# ──────────────────────────────────────────────────────────
#
# Option A — Shell export (Linux/macOS):
#   export APP_DB_URL=jdbc:postgresql://...
#   java -jar target/event-api-0.0.1-SNAPSHOT.jar --spring.profiles.active=prod
#
# Option B — PowerShell (Windows):
#   $env:APP_DB_URL = "jdbc:postgresql://..."
#   java -jar target/event-api-0.0.1-SNAPSHOT.jar --spring.profiles.active=prod
#
# Option C — Docker / Docker Compose:
#   Pass variables via 'environment' block in docker-compose.yml
#   or reference a .env file with 'env_file: .env'
#
# Option D — CI/CD (GitHub Actions, Azure DevOps, etc.):
#   Set these as repository secrets and inject them into
#   the deployment step's environment.
# ──────────────────────────────────────────────────────────
